{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Program",
  "description": "University program data schema (medium depth - Phase 1)",
  "type": "object",
  "properties": {
    "name_de": {
      "type": "string",
      "description": "Program name in original language, e.g. Produktdesign"
    },
    "name_en": {
      "type": "string",
      "description": "English program name, e.g. Industrial Design"
    },
    "name_cn": {
      "type": "string",
      "description": "Chinese program name"
    },
    "slug": {
      "type": "string",
      "description": "URL-safe identifier, e.g. industrial-design"
    },
    "degree": {
      "type": "string",
      "enum": ["ba", "ma", "bfa", "mfa", "diplom", "phd", "dr", "state_exam", "bsc", "msc", "mphil", "bdes", "mdes", "march", "other"],
      "description": "Degree type: ba=Bachelor of Arts, ma=Master of Arts, bfa=Bachelor of Fine Arts, mfa=Master of Fine Arts, diplom=Diplom, phd=Doctor of Philosophy, dr=Doctor (Dr. phil., Dr.-Ing.), state_exam=State Examination, bsc=Bachelor of Science, msc=Master of Science, mphil=Master of Philosophy, bdes=Bachelor of Design, mdes=Master of Design, march=Master of Architecture, other"
    },
    "degree_title": {
      "type": "string",
      "description": "Full degree title, e.g. Bachelor of Arts (B.A.)"
    },
    "language": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Languages of instruction, e.g. [\"de\", \"en\"]"
    },
    "duration_semesters": {
      "type": "integer",
      "description": "Standard duration in semesters"
    },
    "credits": {
      "type": "integer",
      "description": "Total credit points for the program, e.g. 120 for ECTS"
    },
    "credits_system": {
      "type": "string",
      "description": "Credit system used, e.g. ECTS, CATS, US credits"
    },
    "start_semester": {
      "type": "string",
      "description": "When the program starts, e.g. 'Winter semester' or 'Winter and summer'"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Program page URL"
    },
    "department": {
      "type": "string",
      "description": "Faculty/Department name"
    },
    "faculty_url": {
      "type": "string",
      "format": "uri",
      "description": "Faculty page URL"
    },
    "focus_areas": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Key focus areas, e.g. ['product design', 'UX', 'sustainability']"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Standard classification tags from the controlled vocabulary (see tags.yaml). Assigned generously based on program content."
    },
    "admission_requirements": {
      "type": "string",
      "description": "Summary of admission requirements"
    },
    "language_requirements": {
      "type": "object",
      "properties": {
        "german": { "type": "string", "description": "e.g. DSH-2, TestDaF 4x4 (if applicable)" },
        "english": { "type": "string", "description": "e.g. IELTS 6.5, TOEFL 80 (if applicable)" }
      }
    },
    "portfolio_required": {
      "type": "boolean",
      "description": "Whether a portfolio/mappe is required"
    },
    "portfolio_details": {
      "type": "string",
      "description": "Portfolio requirements details"
    },
    "application_process": {
      "type": "string",
      "description": "How to apply - steps and portal info"
    },
    "application_deadlines": {
      "type": "object",
      "properties": {
        "winter_semester": { "type": "string", "description": "Fall/Winter intake deadline" },
        "summer_semester": { "type": "string", "description": "Spring/Summer intake deadline" },
        "notes": { "type": "string" }
      }
    },
    "curriculum_summary": {
      "type": "string",
      "description": "Summary of key modules and curriculum structure"
    },
    "tuition": {
      "type": "object",
      "properties": {
        "tuition_free": { "type": "boolean" },
        "amount": { "type": "number", "description": "Tuition fee amount" },
        "currency": { "type": "string", "description": "ISO 4217 currency code: EUR, GBP, USD" },
        "period": { "type": "string", "description": "Fee period: semester, year, total" },
        "notes": { "type": "string" }
      }
    },
    "scholarship_info": {
      "type": "string",
      "description": "Available scholarships or funding info (Phase 2 deep field)"
    },
    "contact": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "office_hours": { "type": "string" }
      }
    },
    "num_places": {
      "type": "integer",
      "description": "Number of available places (if known)"
    },
    "application_portal": {
      "type": "string",
      "description": "Application portal name or platform, e.g. uni-assist, UCAS, Common App"
    },
    "application_portal_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the application portal"
    },
    "url_en": {
      "type": "string",
      "format": "uri",
      "description": "English version of program page URL (if available)"
    },
    "city": {
      "type": "string",
      "description": "City where the program is offered"
    },
    "state": {
      "type": "string",
      "description": "State/province/region"
    },
    "country": {
      "type": "string",
      "description": "ISO country code"
    },
    "career_perspectives": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Potential career paths after graduation"
    },
    "workshops": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Workshop name (original language)" },
          "en": { "type": "string", "description": "Workshop name (English)" }
        }
      },
      "description": "Available workshops and facilities"
    },
    "professors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "chair": { "type": "string", "description": "Professorship/Chair name" },
          "role": { "type": "string", "description": "Role in program" }
        }
      },
      "description": "Professors associated with the program"
    },
    "additional_contacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" }
        }
      },
      "description": "Additional contact persons"
    },
    "last_crawled": {
      "type": "string",
      "format": "date-time"
    },
    "source_urls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    }
  },
  "required": ["name_en", "slug", "degree", "url"]
}
