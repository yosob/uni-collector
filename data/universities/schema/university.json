{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "University",
  "description": "University/institution data schema (medium depth)",
  "type": "object",
  "properties": {
    "name_de": {
      "type": "string",
      "description": "Official name in original language"
    },
    "name_en": {
      "type": "string",
      "description": "English name"
    },
    "name_cn": {
      "type": "string",
      "description": "Chinese name"
    },
    "slug": {
      "type": "string",
      "description": "URL-safe identifier, e.g. bauhaus-universitaet-weimar"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Official website URL"
    },
    "country": {
      "type": "string",
      "description": "ISO 3166-1 alpha-2 country code"
    },
    "city": {
      "type": "string",
      "description": "City name"
    },
    "state": {
      "type": "string",
      "description": "State/province/region"
    },
    "type": {
      "type": "string",
      "enum": ["universitaet", "fachhochschule", "kunsthochschule", "musikhochschule", "university", "art_school", "college", "institute", "other"],
      "description": "Institution type"
    },
    "founded_year": {
      "type": "integer",
      "description": "Year founded"
    },
    "student_count": {
      "type": "integer",
      "description": "Approximate number of students"
    },
    "languages": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Languages of instruction, e.g. [\"de\", \"en\"]"
    },
    "tuition": {
      "type": "object",
      "properties": {
        "tuition_free": { "type": "boolean" },
        "amount": { "type": "number", "description": "Tuition fee amount" },
        "currency": { "type": "string", "description": "ISO 4217 currency code: EUR, GBP, USD" },
        "period": { "type": "string", "description": "Fee period: semester, year, total" },
        "notes": { "type": "string" }
      },
      "description": "Tuition information"
    },
    "application_deadlines": {
      "type": "object",
      "properties": {
        "winter_semester": { "type": "string", "description": "Fall/Winter intake deadline, e.g. 'July 15'" },
        "summer_semester": { "type": "string", "description": "Spring/Summer intake deadline, e.g. 'January 15'" },
        "notes": { "type": "string" }
      },
      "description": "General application deadlines"
    },
    "application_portal": {
      "type": "string",
      "description": "URL or name of application portal, e.g. uni-assist, UCAS, direct"
    },
    "application_portal_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the application portal"
    },
    "faculties": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name_de": { "type": "string", "description": "Faculty name in original language" },
          "name_en": { "type": "string", "description": "Faculty name in English" }
        }
      },
      "description": "List of faculties/departments"
    },
    "overview": {
      "type": "string",
      "description": "Brief overview paragraph"
    },
    "programs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of program slugs under this university"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Aggregated tags from all programs. Auto-generated by aggregate_tags.py."
    },
    "last_crawled": {
      "type": "string",
      "format": "date-time"
    },
    "source_urls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    }
  },
  "required": ["name_en", "slug", "url", "country"]
}
